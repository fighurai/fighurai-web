# --- Production (fighurai.com) ---
# Set in your host (e.g. Vercel → Project → Environment Variables). Do not commit real secrets.
# Public canonical URL — used for sitemap/robots; defaults to https://fighurai.com if unset.
# NEXT_PUBLIC_SITE_URL=https://fighurai.com

# Membership page “Applications” demo: full HTTPS URL to an MP4 (overrides public/videos/sparky-demo*.mp4).
# Upload 0417.mp4 (or any H.264 MP4) to Vercel Blob, S3, Cloudinary, etc., then paste the public URL here.
# NEXT_PUBLIC_MEMBERSHIP_DEMO_VIDEO_URL=https://your-cdn.example.com/path/demo.mp4

# Anthropic (Ask tab — Claude in model picker)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Optional: other models in Ask (add at least one key you want to use)
# Groq — free tier: https://console.groq.com
# GROQ_API_KEY=
# OpenRouter — many models (Nemotron, Qwen, Llama, etc.): https://openrouter.ai
# OPENROUTER_API_KEY=
# OPENROUTER_REFERER=https://fighurai.com
# NVIDIA Spark / NIM — https://build.nvidia.com
# NVIDIA_API_KEY=
# FIGHURAI_DEFAULT_CHAT_MODEL=anthropic:claude-sonnet-4-5-20250929

# Google Sheet — append sign-ups / sign-ins (service account)
# 1. Google Cloud Console → APIs → enable "Google Sheets API"
# 2. IAM → Service Accounts → create key JSON
# 3. Open your sheet → Share → paste the service account email → Editor
# 4. Row 1 in the sheet (optional): Timestamp | Name | Email | Action
GOOGLE_CLIENT_EMAIL=your-sa@project.iam.gserviceaccount.com
# Paste the full private key; use \n for newlines in .env
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID=1TRw1BULbggY4qHhb-30zx42Vq-QjhZ0VkDtuazmd8wc
# Optional if the tab is not named Sheet1
# GOOGLE_SHEETS_TAB_NAME=Sheet1

# FighurFinance — default: /fighurfinance embeds files from public/finance-dashboard/
# (see financial-dashboard/SETUP.txt). To open a separate dev server instead:
# NEXT_PUBLIC_FIGHUR_FINANCE_URL=http://localhost:5173

# Contact form (Resend — https://resend.com)
RESEND_API_KEY=
# "From" must be allowed in your Resend project (verify fighurai.com or use onboarding@resend.dev for tests)
CONTACT_FROM_EMAIL=FIGHURAI Contact <onboarding@resend.dev>
# Inbox for submissions (default: hello@fighurai.com)
# CONTACT_TO_EMAIL=hello@fighurai.com
